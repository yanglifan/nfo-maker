# NFO Maker 环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# Web 服务端口
WEB_PORT=3000

# 应用内部端口
PORT=3000

# 媒体目录映射（请修改为 NAS 上的实际路径）
# 示例 1: 电影目录
MEDIA_DIR_1=/mnt/share/Media/Movies
# 示例 2: 电视剧目录
MEDIA_DIR_2=/mnt/share/Media/TVShows

# 如需更多目录，可添加 MEDIA_DIR_3, MEDIA_DIR_4 等
# 并同时修改 docker-compose.yml 添加对应的挂载点

# 注意：定时任务的扫描配置（cron、目录、间隔等）
# 请在 Web 界面的 /cron 页面进行配置，会自动持久化到 data/scan-config.json
